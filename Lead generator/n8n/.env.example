# Kopieer dit bestand naar .env en vul de waarden in.
# Voeg .env toe aan .gitignore — dit bestand bevat secrets.

# === n8n core ===
# Domain waarop n8n bereikbaar wordt (zonder https://)
N8N_HOST=n8n.jouwdomein.nl

# Login voor de n8n web UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=verander_dit_naar_iets_lang_en_random

# Encryptiesleutel voor opgeslagen credentials. Genereer via:
#   openssl rand -hex 32
# Wijzig dit NOOIT na eerste keer opslaan van credentials, anders verlies je toegang.
N8N_ENCRYPTION_KEY=verander_dit_naar_64_random_hex_chars

# === Apollo.io ===
# Maak gratis account, ga naar Settings -> Integrations -> API
APOLLO_API_KEY=

# === HubSpot ===
# Settings -> Integrations -> Private Apps -> Create
# Scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# === Resend (email delivery) ===
# https://resend.com/api-keys
# Of vervang met SendGrid/Mailgun — pas dan workflow-lead-intake.json aan
RESEND_API_KEY=

# === Agency identiteit ===
AGENCY_NAME=AILeads NL
AGENCY_INTERNAL_EMAIL=info@jouwagency.nl
AGENCY_FROM_EMAIL=hallo@jouwagency.nl
NOTIFICATION_FROM_EMAIL=notifications@jouwagency.nl

# === Optioneel: Postgres (alleen als je naar productie schaalt) ===
# POSTGRES_PASSWORD=
